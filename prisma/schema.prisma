model Task {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean? @default(false)
  authorId  Int?
  author    User?    @relation(fields: [authorId], references: [id])
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  published Boolean  @default(false)
  authorId  Int?
  author    User?    @relation(fields: [authorId], references: [id])
}

model Logs{
  id       Int      @id @default(autoincrement())
  statusCode Int
  timestamp DateTime
  path String @db.Text
  error String @db.Text
  errorCode String @db.Text
  session_id Int?

  user User? @relation(fields: [session_id], references: [id])
}
